<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PreviousPractice.ViewModels"
             x:Class="PreviousPractice.MainPage"
             x:DataType="viewModels:MainViewModel"
             x:Name="Root"
             Title="기출문제 연습프로그램">

    <ContentPage.BindingContext>
        <viewModels:MainViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">
            <Label Text="기출문제 연습프로그램" FontSize="30" FontAttributes="Bold" />

            <Entry Placeholder="카테고리 이름" Text="{Binding CategoryName}" />

            <Label Text="정답 매핑(예: 1:3|4,2:정답)" />
            <Editor HeightRequest="140" Text="{Binding AnswerMapText}" />

            <Button Text="정답 파싱 테스트" Command="{Binding ParseAnswerCommand}" />

            <Label Text="{Binding Feedback}" />

            <Frame Padding="12" BorderColor="#CBD5E1" HasShadow="True">
                <Label Text="오답/카테고리/연습 로직은 다음 단계로 추가 예정입니다." />
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
