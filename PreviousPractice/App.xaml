<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PreviousPractice.App">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="Primary">#0F172A</Color>
            <Color x:Key="Accent">#0F766E</Color>
            <Color x:Key="PageBackgroundColor">#F3F6FA</Color>
            <Color x:Key="SurfaceColor">#FFFFFF</Color>
            <Color x:Key="SurfaceMutedColor">#EAF0F6</Color>
            <Color x:Key="BorderColor">#94A3B8</Color>
            <Color x:Key="PrimaryTextColor">#0F172A</Color>
            <Color x:Key="SecondaryTextColor">#334155</Color>
            <Color x:Key="MutedTextColor">#475569</Color>
            <Color x:Key="InputBackgroundColor">#FFFFFF</Color>
            <Color x:Key="InputTextColor">#0F172A</Color>
            <Color x:Key="InputPlaceholderColor">#64748B</Color>
            <Color x:Key="ButtonBackgroundColor">#0F172A</Color>
            <Color x:Key="ButtonTextColor">#FFFFFF</Color>
            <Color x:Key="ButtonDisabledBackgroundColor">#94A3B8</Color>
            <Color x:Key="ButtonDisabledTextColor">#F8FAFC</Color>
            <Color x:Key="InfoSurfaceColor">#DBEAFE</Color>
            <Color x:Key="InfoTextColor">#1E3A8A</Color>
            <Color x:Key="SuccessSurfaceColor">#DCFCE7</Color>
            <Color x:Key="SuccessTextColor">#166534</Color>
            <Color x:Key="DangerSurfaceColor">#FEE2E2</Color>
            <Color x:Key="DangerTextColor">#991B1B</Color>

            <Style TargetType="NavigationPage">
                <Setter Property="BarBackgroundColor" Value="{StaticResource Primary}" />
                <Setter Property="BarTextColor" Value="{StaticResource ButtonTextColor}" />
            </Style>

            <Style TargetType="ContentPage">
                <Setter Property="BackgroundColor" Value="{StaticResource PageBackgroundColor}" />
            </Style>

            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
            </Style>

            <Style TargetType="Frame">
                <Setter Property="BackgroundColor" Value="{StaticResource SurfaceColor}" />
                <Setter Property="BorderColor" Value="{StaticResource BorderColor}" />
                <Setter Property="HasShadow" Value="False" />
                <Setter Property="CornerRadius" Value="16" />
            </Style>

            <Style TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource ButtonBackgroundColor}" />
                <Setter Property="TextColor" Value="{StaticResource ButtonTextColor}" />
                <Setter Property="BorderColor" Value="{StaticResource ButtonBackgroundColor}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="14,10" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup Name="CommonStates">
                            <VisualState Name="Normal" />
                            <VisualState Name="Disabled">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="{StaticResource ButtonDisabledBackgroundColor}" />
                                    <Setter Property="BorderColor" Value="{StaticResource ButtonDisabledBackgroundColor}" />
                                    <Setter Property="TextColor" Value="{StaticResource ButtonDisabledTextColor}" />
                                    <Setter Property="Opacity" Value="1" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </Setter>
            </Style>

            <Style TargetType="Entry">
                <Setter Property="BackgroundColor" Value="{StaticResource InputBackgroundColor}" />
                <Setter Property="TextColor" Value="{StaticResource InputTextColor}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource InputPlaceholderColor}" />
                <Setter Property="MinimumHeightRequest" Value="44" />
            </Style>

            <Style TargetType="Editor">
                <Setter Property="BackgroundColor" Value="{StaticResource InputBackgroundColor}" />
                <Setter Property="TextColor" Value="{StaticResource InputTextColor}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource InputPlaceholderColor}" />
                <Setter Property="MinimumHeightRequest" Value="88" />
            </Style>

            <Style TargetType="Picker">
                <Setter Property="BackgroundColor" Value="{StaticResource InputBackgroundColor}" />
                <Setter Property="TextColor" Value="{StaticResource InputTextColor}" />
                <Setter Property="TitleColor" Value="{StaticResource InputPlaceholderColor}" />
                <Setter Property="MinimumHeightRequest" Value="44" />
            </Style>

            <Style TargetType="CheckBox">
                <Setter Property="Color" Value="{StaticResource Primary}" />
            </Style>

            <Style TargetType="Switch">
                <Setter Property="OnColor" Value="{StaticResource Accent}" />
                <Setter Property="ThumbColor" Value="{StaticResource SurfaceColor}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
